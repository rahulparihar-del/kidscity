# Supabase URL and Publishable Anon Key (for fetching products and images)
VITE_SUPABASE_URL=https://your_supabase_project_url.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Places API credentials for the live reviews feature.
# Copy this file to ".env" for local testing, and set the same values in your
# hosting dashboard (Vercel / Netlify) for production.
#
# IMPORTANT: never commit the real .env file. It is already covered by .gitignore.

# API key from Google Cloud Console with the "Places API (New)" enabled.
GOOGLE_PLACES_API_KEY=your_api_key_here

# The Place ID of your Google Business Profile.
# Find it at: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=your_place_id_here
